{
  "name": "comparo",
  "version": "0.1.0",
  "description": "MCP server that orchestrates Claude Code, Gemini CLI, and Codex CLI for cross-validation",
  "type": "module",
  "bin": {
    "comparo": "./bin/comparo.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "keywords": ["mcp", "claude", "gemini", "codex", "cross-validation", "ai"],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
